# Public Expo/mobile variables only.
# These values are bundled into the app, so never put backend secrets here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1

# RevenueCat public SDK keys are safe for the mobile app.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_public_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_public_android_key

# Do not add these here:
# SUPABASE_SERVICE_ROLE_KEY
# GEMINI_API_KEY
# REVENUECAT_WEBHOOK_SECRET
# REVENUECAT_API_KEY
# RESEND_API_KEY
# CALENDLY_API_KEY
# EXPO_ACCESS_TOKEN
