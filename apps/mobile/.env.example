# Public Expo/mobile variables only.
# These values are bundled into the app, so never put backend secrets here.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_API_BASE_URL=https://your-project-ref.supabase.co/functions/v1
EXPO_PUBLIC_APP_ORIGIN=https://slicemydebt.com

# RevenueCat public SDK keys are safe for the mobile app.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_public_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_public_android_key

# EAS/App Store submission values are used by release operators.
# Keep real values in your local shell or EAS secrets, not in committed env files.
EXPO_APPLE_ID=apple-developer-login@example.com
ASC_APP_ID=1234567890
APPLE_TEAM_ID=ABCDE12345
IOS_BUILD_NUMBER=1
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Do not add these here:
# SUPABASE_SERVICE_ROLE_KEY
# GEMINI_API_KEY
# REVENUECAT_WEBHOOK_SECRET
# REVENUECAT_API_KEY
# RESEND_API_KEY
# CALENDLY_API_KEY
# EXPO_ACCESS_TOKEN
